# Control what gets published; merges with repo-root .gitignore (pub walks up to git root).
# Root .gitignore ignores ios/RaTeX.xcframework and android jniLibs so they are not committed;
# CI builds them before publish. Without the ! rules below, dart pub publish would omit them.

# Dart / Pub
.dart_tool/
.packages
.pub-cache/
.pub/
*.iml
.idea/
.vscode/

# Build / IDE
*.log
.DS_Store

# Ship CI-built native artifacts (negate repo-root ignore patterns).
!ios/RaTeX.xcframework/
!ios/RaTeX.xcframework/**
!android/src/main/jniLibs/
!android/src/main/jniLibs/**
